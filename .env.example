# wtec cluster credentials — copy to .env and fill in values
# NEVER commit .env to version control

TOPOSLAB_CLUSTER_HOST=
TOPOSLAB_CLUSTER_PORT=22
TOPOSLAB_CLUSTER_USER=
TOPOSLAB_CLUSTER_PASS=
# Recommended: use SSH key instead of password
TOPOSLAB_CLUSTER_KEY=~/.ssh/id_rsa

# Materials Project API key (used by default mp-based slab template)
MP_API_KEY=
# Optional legacy alias used by pymatgen/mp-api:
# PMG_MAPI_KEY=

# Workspace on cluster
TOPOSLAB_REMOTE_WORKDIR=/home/$USER/wtec_runs

# Default DFT engine used by init-time validation and generated templates.
TOPOSLAB_DEFAULT_DFT_ENGINE=qe

# MPI cores per node (default for PBS scripts)
TOPOSLAB_MPI_CORES=32

# Optional queue-specific cores-per-node override for queue fallback.
# Format: queue:cores,queue:cores (example below)
# TOPOSLAB_MPI_CORES_BY_QUEUE=g4:64,g3:48,g2:32,g1:16

# QE pseudopotential directory on cluster (must contain required .UPF files)
TOPOSLAB_QE_PSEUDO_DIR=/home/$USER/qe/pseudo/pslibrary.1.0.0

# SIESTA pseudopotential directory on cluster (must contain required .psf/.psml files)
TOPOSLAB_SIESTA_PSEUDO_DIR=/home/$USER/siesta/pseudo

# VASP pseudopotential root on cluster (contains species subdirs with POTCAR)
TOPOSLAB_VASP_PSEUDO_DIR=/home/$USER/vasp/potpaw_PBE

# ABACUS pseudopotential/orbital directories on cluster
TOPOSLAB_ABACUS_PSEUDO_DIR=/home/$USER/abacus/pseudo
TOPOSLAB_ABACUS_ORBITAL_DIR=/home/$USER/abacus/orbital
#
# SIESTA capability guardrails (validated during `wtec init`)
# TOPOSLAB_SIESTA_MIN_VERSION=4.1
# TOPOSLAB_SIESTA_REQUIRE_D3=1
# TOPOSLAB_SIESTA_REQUIRE_WANNIER=1

# Default material used for init-time required-UPF checks.
TOPOSLAB_DEFAULT_MATERIAL=TaP

# Optional source directory used by `wtec init` to seed TOPOSLAB_QE_PSEUDO_DIR when empty.
# Can point to pslibrary tree containing generated .UPF files.
# TOPOSLAB_QE_PSEUDO_SOURCE_DIR=/home/$USER/src/QE_pseudo/pslibrary

# Optional threading controls exported in PBS scripts
# TOPOSLAB_OMP_THREADS=64

# Optional environment modules to load before command checks/job runs
# Comma-separated, e.g. qe/7.2,openmpi/4.1
# TOPOSLAB_CLUSTER_MODULES=

# Optional extra PATH entries for cluster runtime/command checks.
# Comma-separated absolute directories that contain executables (pw.x, wannier90.x, etc.)
# TOPOSLAB_CLUSTER_BIN_DIRS=/home/$USER/src/q-e/bin,/home/$USER/src/wannier90

# Optional source roots used by `wtec init` when auto-building missing tools.
# TOPOSLAB_QE_SOURCE_DIR=/home/$USER/src/q-e
# TOPOSLAB_SIESTA_SOURCE_DIR=/home/$USER/src/siesta
# TOPOSLAB_ABACUS_SOURCE_DIR=/home/$USER/src/abacus-develop
# TOPOSLAB_WANNIER90_SOURCE_DIR=/home/$USER/src/wannier90

# Optional make parallelism for cluster-side source builds done by `wtec init`.
# TOPOSLAB_CLUSTER_BUILD_JOBS=8
