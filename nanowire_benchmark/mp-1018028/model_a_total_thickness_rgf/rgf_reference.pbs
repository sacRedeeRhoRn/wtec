#!/bin/bash
#PBS -N rgf_tscan
#PBS -l select=1:ncpus=64:mpiprocs=1:ompthreads=64
#PBS -l walltime=02:00:00

#PBS -q g4
#PBS -j oe
#PBS -o /home/msj/Desktop/playground/electroics/wtec/nanowire_benchmark/mp-1018028/model_a_total_thickness_rgf/rgf_tscan.log

# ── environment ─────────────────────────────────────────────────────────────
module load QE/7.2
export OMP_NUM_THREADS=64
export MKL_NUM_THREADS=64
export OPENBLAS_NUM_THREADS=64
export NUMEXPR_NUM_THREADS=64
export OMP_DYNAMIC=FALSE
export MKL_DYNAMIC=FALSE
export OMP_PROC_BIND=spread
export OMP_PLACES=cores
export PYTHONUNBUFFERED=1

# ── working directory ────────────────────────────────────────────────────────
set -euo pipefail
cd /home/msj/Desktop/playground/electroics/wtec/nanowire_benchmark/mp-1018028/model_a_total_thickness_rgf
exec > >(tee -a /home/msj/Desktop/playground/electroics/wtec/nanowire_benchmark/mp-1018028/model_a_total_thickness_rgf/wtec_job.log) 2>&1
echo "[wtec][runtime] start $(date -Is)"

# ── commands ─────────────────────────────────────────────────────────────────
# IMPORTANT: all parallel execution uses mpirun backend.
# Fork-based launchstyle is FORBIDDEN in this package.
